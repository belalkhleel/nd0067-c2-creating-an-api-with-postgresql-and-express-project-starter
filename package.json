{
  "name": "storefront_backend",
  "version": "0.1.0",
  "description": "",
  "main": "server.ts",
  "scripts": {
    "start": "npx tsx src/server.ts",
    "watch": "npx tsx watch src/server.ts",
    "test": "cross-env ENV=test jest --forceExit",
    "tsc": "tsc",
    "db-up": "db-migrate up",
    "db-down": "db-migrate down",
    "test-db-up": "db-migrate up --env test",
    "test-db-down": "db-migrate down --env test"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/*.spec.ts"
    ]
  },
  "author": "Udacity",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "body-parser": "^1.19.0",
    "db-migrate": "^0.11.14",
    "db-migrate-pg": "^1.5.2",
    "dotenv": "^17.4.2",
    "express": "^4.17.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.22.0",
    "typescript": "^4.1.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.9",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pg": "^7.14.7",
    "@types/supertest": "^7.2.0",
    "cross-env": "^10.1.0",
    "jest": "^30.4.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "tsc-watch": "^4.2.9",
    "tsx": "^4.22.4"
  }
}
